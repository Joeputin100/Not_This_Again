; Iter 327: background villains — Slippery Pete + the Candy Rustler rig
; lurk behind the menu. The Rustler is the jointed-puppet rig (self-builds
; + idle-sways via candy_rustler_rig.gd); positioned lower-right, scaled
; down and dimmed so it reads as a background lurker. Tap zones live in the
; UI layer (PeteTap / RustlerTap) so they're tappable without eating the
; PLAY button.
[node name="RustlerRig" type="Node2D" parent="."]
position = Vector2(393, 1224)
scale = Vector2(0.72, 0.72)
modulate = Color(0.8, 0.8, 0.85, 0.8)
script = ExtResource("6_rustler_rig")
silent = true


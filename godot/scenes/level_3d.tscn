[node name="Terrain3D" type="Node2D" parent="."]

; Iter 94: SubViewport size halved 1080×1920 → 540×960 and
; render_target_update_mode set to WHEN_VISIBLE (3) instead of ALWAYS (4)
; to reduce mobile GPU load. Persistent log diagnosis (iter 93) showed
; level_3d._ready never fires — the freeze is in Godot's scene-load
; step (texture upload / shader compile / SubViewport init) before any
; user GDScript runs. The Sprite2D below upscales 2× to fill the screen.
[node name="SubViewport" type="SubViewport" parent="Terrain3D"]
size = Vector2i(540, 960)
own_world_3d = true
transparent_bg = false
render_target_update_mode = 3

; Camera3D + lights cloned from terrain_3d.tscn so the dirt looks
; identical between gameplay levels and this 3D prototype.
[node name="Camera3D" type="Camera3D" parent="Terrain3D/SubViewport"]
transform = Transform3D(1, 0, 0, 0, 0.866, 0.5, 0, -0.5, 0.866, 0, 3, 2)
fov = 70.0

; Iter 94: shadow_enabled=false on both lights. Shadow maps are an
; extra render pass per light per frame — measurable savings on
; mobile GPU + may unblock the level_3d scene load.
[node name="DirectionalLight3D" type="DirectionalLight3D" parent="Terrain3D/SubViewport"]
transform = Transform3D(0.866, -0.354, 0.354, 0, 0.707, 0.707, -0.5, -0.612, 0.612, 0, 8, 0)
light_energy = 1.25
light_color = Color(1.0, 0.94, 0.82, 1)
shadow_enabled = false

[node name="FillLight" type="DirectionalLight3D" parent="Terrain3D/SubViewport"]
transform = Transform3D(-0.866, 0.354, -0.354, 0, 0.707, 0.707, 0.5, 0.612, -0.612, 0, 8, 0)
light_energy = 0.35
light_color = Color(0.7, 0.78, 1.0, 1)
shadow_enabled = false

[node name="Ground" type="MeshInstance3D" parent="Terrain3D/SubViewport"]
mesh = SubResource("PlaneMesh_ground")
material_override = SubResource("StandardMaterial3D_dirt")

; Iter 95: ALL 3D content (cowboy + mountains + 8 container Node3Ds)
; moved to script-side spawn in level_3d.gd._ready. Hypothesis: bundling
; ~15 nodes including a Sprite3D with a 1.7MB texture + 4 MeshInstance3D
; with materials + the dirt MeshInstance3D + 2 lights into the .tscn
; was overloading mobile scene-load (texture upload + shader compile
; happens synchronously). Lazy script-side addition spreads the work
; across multiple frames + lets the breadcrumbs reveal which step hangs
; if any.
;
; Scene file now matches terrain_3d.tscn EXACTLY in SubViewport contents:
; Camera3D + 2 Lights + Ground. That structure is proven-working in
; gameplay levels (level.tscn instances terrain_3d.tscn successfully).

; SubViewport renders into this Sprite2D which spans the full screen.
; Iter 94: SubViewport halved to 540×960 so scale 2 upscales to fill
; the 1080×1920 screen. The visual loss vs. native is acceptable
; given the user-side freeze risk it eliminates.
[node name="Sprite" type="Sprite2D" parent="Terrain3D"]
position = Vector2(540, 960)
scale = Vector2(2, 2)


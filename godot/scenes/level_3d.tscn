; Iter 64: 3D cowboy lives INSIDE the SubViewport's 3D scene — it's a
; Sprite3D billboard always facing the camera. Pixel-size tuned so the
; sprite reads ~2 world units tall (matches the dirt scale).
; Iter 71: pixel_size 0.0003 → 0.002 (sprite ~0.68×0.89 world units —
; visible but not dominant). y from 0.5 → 0.45 so the sprite's bottom
; sits at y≈0 (on the dirt plane) instead of floating above.
[node name="Cowboy3D" type="Sprite3D" parent="Terrain3D/SubViewport"]
transform = Transform3D(1, 0, 0, 0, 1, 0, 0, 0, 1, 0, 0.45, 1.5)
pixel_size = 0.002
billboard = 1
alpha_cut = 1
texture = ExtResource("5_cowboy")

; Obstacles spawn as children of this Node3D so level_3d.gd can iterate
; them. CSGBox3D placeholders for iter 64 (iter 65+ will swap to proper
; 3D entity meshes per type).
[node name="Obstacles" type="Node3D" parent="Terrain3D/SubViewport"]

; Iter 66: bullets spawn as children of this Node3D. CSGSphere3D emissive
; jelly beans — replaceable with proper bullet meshes in a future iter.
[node name="Bullets" type="Node3D" parent="Terrain3D/SubViewport"]

; Iter 75: gates spawn here. Each gate = two side-by-side colored door
; quads, each with a Label3D math value. Cowboy walks through one of
; the two doors to apply that effect.
[node name="Gates" type="Node3D" parent="Terrain3D/SubViewport"]

; Iter 76: outlaw enemies spawn here. Each = a tall red CSGBox3D that
; scrolls toward the camera + fires red bullets back at the cowboy.
[node name="Outlaws" type="Node3D" parent="Terrain3D/SubViewport"]

; Iter 76: outlaw bullets — distinct from posse bullets so collision
; checks can distinguish 'incoming' vs 'outgoing'.
[node name="OutlawBullets" type="Node3D" parent="Terrain3D/SubViewport"]

; Iter 77: boss container. Slippery Pete (or future bosses) lives here.
; Spawned dynamically after PETE_SPAWN_DELAY into the level.
[node name="Boss" type="Node3D" parent="Terrain3D/SubViewport"]


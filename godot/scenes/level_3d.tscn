[gd_scene load_steps=3 format=3 uid="uid://b0nttg_lvl3d_001"]

; Iter 96: replaced the inline SubViewport + dirt material + Camera3D
; + lights + Ground with a terrain_3d.tscn INSTANCE — the same pattern
; level.tscn uses (and which is proven-working on Android).
;
; The previous inline version froze on scene-load on Android (ANR kill
; after ~18s with no _ready breadcrumb), even after iter 95 moved all
; the cowboy/mountains/containers to script-side spawn. Since level.tscn
; uses the SAME dirt textures via the same terrain_3d.tscn instance and
; runs fine, the bug had to be in level_3d.tscn's inline copy of the
; SubViewport setup. Switching to the instance makes the two scenes
; share an identical Terrain3D code path — if instance-mode works in
; gameplay, it works here.

[ext_resource type="Script" path="res://scripts/level_3d.gd" id="1_lvl3d"]
[ext_resource type="PackedScene" path="res://scenes/terrain_3d.tscn" id="2_terrain"]

[node name="Level3D" type="Node2D"]
script = ExtResource("1_lvl3d")

[node name="Background" type="ColorRect" parent="."]
offset_right = 1080.0
offset_bottom = 1920.0
color = Color(0.094, 0.067, 0.027, 1)
mouse_filter = 2

; Iter 96: Terrain3D as an instance of terrain_3d.tscn, mirroring
; level.tscn line 31. All SubViewport / dirt / camera / lights / ground
; / sprite wiring is inherited from the .tscn instance. level_3d.gd
; references the SubViewport via $Terrain3D/SubViewport which resolves
; the same way it would for the inline version — the instance preserves
; child node names.
[node name="Terrain3D" parent="." instance=ExtResource("2_terrain")]

[node name="UI" type="CanvasLayer" parent="."]


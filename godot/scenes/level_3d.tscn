; Iter 77: WIN overlay — pops when Pete is defeated. Mirrors 2D
; level.tscn's WinOverlay structure.
; Iter 108: WAS broken — anchor_right=1.0 AND offset_right=1080.0
; STACK additively. The overlay was 2160px wide on a 1080px screen,
; so the centered Label rendered with its center at x=1080 (off-screen
; right by half its width) and only the leftmost ~400px ('BO' of
; 'BOUNTY!') was visible. Same bug fixed on FailOverlay below.
; Correct pattern: anchor=1.0 with offset=0 OR no anchor with offset=1080.
[node name="WinOverlay" type="ColorRect" parent="UI"]
anchor_right = 1.0
anchor_bottom = 1.0
color = Color(0.226, 0.157, 0.078, 0.88)
visible = false
mouse_filter = 2


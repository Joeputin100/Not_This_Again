[gd_scene load_steps=9 format=3 uid="uid://b0nttg_sp1_crowd_001"]

; SP1 debug crowd viewer — 3D crowd preview wired through a SubViewport
; so it renders correctly under the project's mobile / canvas_items
; pipeline (same pattern as terrain_3d.tscn / level_3d.tscn). The 3D
; content (camera, lights, grass plane, crowd) lives inside the
; SubViewport; a SubViewportContainer displays its texture. The slider /
; d-pad / perf-readout UI sits in a CanvasLayer above. Accessed from
; debug_menu's "RENDERING REBUILD" section.

[ext_resource type="Script" path="res://scripts/sp1_crowd_viewer.gd" id="1_script"]
[ext_resource type="Theme" path="res://assets/theme.tres" id="2_theme"]

[sub_resource type="PlaneMesh" id="PlaneMesh_grass"]
size = Vector2(60, 60)

[sub_resource type="FastNoiseLite" id="GrassNoise"]
noise_type = 1
frequency = 0.08
fractal_octaves = 3

[sub_resource type="NoiseTexture2D" id="GrassNoiseTex"]
width = 256
height = 256
seamless = true
noise = SubResource("GrassNoise")
color_ramp = null

[sub_resource type="StandardMaterial3D" id="StandardMaterial3D_grass"]
albedo_color = Color(0.27, 0.55, 0.20, 1)
albedo_texture = SubResource("GrassNoiseTex")
roughness = 0.95
metallic_specular = 0.0
uv1_scale = Vector3(12, 12, 1)

; Environment provides ambient fill so areas not directly hit by the key
; light still read clearly. The horizon/ambient color is a warm grey-blue,
; tunable later per "level lighting preset" (daylight / sunset / moonlight).
[sub_resource type="Environment" id="Env_daylight"]
background_mode = 1
background_color = Color(0.42, 0.62, 0.85, 1)
ambient_light_source = 2
ambient_light_color = Color(0.78, 0.82, 0.92, 1)
ambient_light_energy = 0.3
tonemap_mode = 2

[sub_resource type="CameraAttributesPractical" id="CamAttr_daylight"]


[node name="SP1CrowdViewer" type="Node2D"]
script = ExtResource("1_script")

[node name="Background" type="ColorRect" parent="."]
offset_right = 1080.0
offset_bottom = 1920.0
color = Color(0.42, 0.62, 0.85, 1)
mouse_filter = 2

[node name="ViewportContainer" type="SubViewportContainer" parent="."]
offset_right = 1080.0
offset_bottom = 1920.0
stretch = true
mouse_filter = 2

[node name="Viewport3D" type="SubViewport" parent="ViewportContainer"]
own_world_3d = true
transparent_bg = false
handle_input_locally = false
size = Vector2i(1080, 1920)
render_target_update_mode = 4

[node name="WorldEnvironment" type="WorldEnvironment" parent="ViewportContainer/Viewport3D"]
environment = SubResource("Env_daylight")

[node name="Camera3D" type="Camera3D" parent="ViewportContainer/Viewport3D"]
transform = Transform3D(1, 0, 0, 0, 1, 0, 0, 0, 1, 0, 8, 8)
current = true
fov = 50.0
attributes = SubResource("CamAttr_daylight")

; Sun-style light pitched ~30° down from horizontal. Shadows disabled here
; because the flipbook + grass_field shaders are `unshaded` (can't cast
; shadows anyway, per Godot 4's Mobile renderer behaviour). The figure
; shadow-cast feature is deferred — blob-shadow planes will replace this.
[node name="KeyLight" type="DirectionalLight3D" parent="ViewportContainer/Viewport3D"]
transform = Transform3D(0.707, 0, -0.707, -0.354, 0.866, -0.354, 0.612, 0.5, 0.612, 4, 8, 0)
light_energy = 1.2
light_color = Color(1.0, 0.96, 0.82, 1)
shadow_enabled = false

[node name="FillLight" type="DirectionalLight3D" parent="ViewportContainer/Viewport3D"]
transform = Transform3D(-0.866, 0.354, -0.354, 0, 0.707, 0.707, 0.5, 0.612, -0.612, 0, 10, 0)
light_energy = 0.35
light_color = Color(0.7, 0.78, 1.0, 1)
shadow_enabled = false

[node name="Grass" type="MeshInstance3D" parent="ViewportContainer/Viewport3D"]
mesh = SubResource("PlaneMesh_grass")
material_override = SubResource("StandardMaterial3D_grass")


[node name="UI" type="CanvasLayer" parent="."]

[node name="Panel" type="PanelContainer" parent="UI"]
anchors_preset = -1
anchor_left = 0.0
anchor_top = 1.0
anchor_right = 0.0
anchor_bottom = 1.0
offset_left = 30.0
offset_top = -900.0
offset_right = 540.0
offset_bottom = -30.0
theme = ExtResource("2_theme")

